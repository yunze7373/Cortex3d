3d.home.lan:80 {
    # 代理后端 API 和静态文件（优先匹配）
    reverse_proxy /api/* localhost:8000
    reverse_proxy /outputs/* localhost:8000
    # 其余所有请求代理到 Vite 前端（catch-all，包括 JS/CSS/HMR）
    reverse_proxy localhost:5173
    encode gzip
}

3d.home.lan:443 {
    # 代理后端 API 和静态文件（优先匹配）
    reverse_proxy /api/* localhost:8000
    reverse_proxy /outputs/* localhost:8000
    # 其余所有请求代理到 Vite 前端（catch-all，包括 JS/CSS/HMR）
    reverse_proxy localhost:5173
    encode gzip
    tls internal
}
